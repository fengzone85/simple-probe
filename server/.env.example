# Server configuration - copy to .env and fill in
PORT=8081
DB_PATH=/data/monitor.db

# Admin token for dashboard (create/edit/delete agents, view data)
ADMIN_TOKEN=change-me-admin-token

# 会话 Cookie 签名密钥（Dashboard 登录态，替代前端明文持有 Token）。
# 务必设为随机长字符串；留空则每次服务端重启会使所有已登录会话失效（需重新登录）。
# 生成：openssl rand -hex 32
SESSION_SECRET=
# 登录会话有效期（毫秒），默认 12 小时
SESSION_TTL_MS=43200000

# 只读 Token（可选）：持有者仅能查看数据（GET 接口），不能增删改。
# 适合给需要看监控但不应拥有管理权限的人 / 看板使用。留空则无只读账号。
READONLY_TOKEN=

# 一键注册令牌（可选）：配置后，受控端可用 `--setup-token <本值>` 自助注册客户端，
# 无需在后台手动「新建客户端」。效果等同管理后台创建，但同样不建立任何指令通道
# （agent 注册后仍只上报指标）。留空则关闭该功能（受控端必须手动在后台获取 ID/Token）。
# 生成：openssl rand -hex 16
SETUP_TOKEN=

# Agent report interval (seconds) - used for online/offline detection
AGENT_INTERVAL=15
# A client is considered offline if no report within this many seconds
OFFLINE_THRESHOLD_SEC=60

# Raw metrics retention (days). Older rows are pruned automatically.
RETENTION_DAYS=30

# ---- Alert thresholds ----
ALERT_CPU_PCT=90
ALERT_MEM_PCT=90
# Min cooldown between repeated alerts of the same type (seconds)
ALERT_COOLDOWN_SEC=1800

# ---- QQ SMTP (alerts) ----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=你的QQ号@qq.com
SMTP_PASS=your_qq_auth_code
ALERT_FROM=你的QQ号@qq.com
ALERT_TO=你的QQ号@qq.com

# ---- Telegram 告警（可选；留空则仅用邮件）----
# 向 @BotFather 创建机器人获取 BOT_TOKEN；把机器人拉进频道/私聊后，
# 访问 https://api.telegram.org/bot<TOKEN>/getUpdates 获取 chat_id（私聊即你的 id，群组为负数）。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
