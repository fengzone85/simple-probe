# Server configuration - copy to .env and fill in
PORT=8080
DB_PATH=/data/monitor.db

# Admin token for dashboard (create/edit/delete agents, view data)
ADMIN_TOKEN=change-me-admin-token

# Agent report interval (seconds) - used for online/offline detection
AGENT_INTERVAL=15
# A client is considered offline if no report within this many seconds
OFFLINE_THRESHOLD_SEC=60

# Raw metrics retention (days). Older rows are pruned automatically.
RETENTION_DAYS=30

# ---- Alert thresholds ----
ALERT_CPU_PCT=90
ALERT_MEM_PCT=90
# Min cooldown between repeated alerts of the same type (seconds)
ALERT_COOLDOWN_SEC=1800

# ---- QQ SMTP (alerts) ----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=3986232@qq.com
SMTP_PASS=your_qq_auth_code
ALERT_FROM=3986232@qq.com
ALERT_TO=3986232@qq.com
